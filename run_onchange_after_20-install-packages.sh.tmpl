#!/bin/bash
#
# Install / sync all Homebrew packages declared in the Brewfile.
#
# Re-runs whenever the Brewfile changes — the hash below is rewritten by
# chezmoi at apply time and forces a new script hash when Brewfile changes.
#
#   Brewfile hash: {{ include "Brewfile" | sha256sum }}
#
set -euo pipefail

BLUE='\033[0;34m'; GREEN='\033[0;32m'; RED='\033[0;31m'; NC='\033[0m'
log_info()    { echo -e "${BLUE}→${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_error()   { echo -e "${RED}✗${NC} $1" >&2; }

BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"

if [[ ! -f "$BREWFILE" ]]; then
    log_error "Brewfile not found at $BREWFILE"
    exit 1
fi

# Make brew available on PATH (chezmoi scripts run in a non-login shell).
if [ "$(uname -m)" = "arm64" ]; then
    BREW_BIN="/opt/homebrew/bin/brew"
else
    BREW_BIN="/usr/local/bin/brew"
fi

eval "$($BREW_BIN shellenv)"

if [[ ! -x "$BREW_BIN" ]]; then
    log_error "brew not on PATH — did run_once_before_00 succeed?"
    exit 1
fi

# ---------------------------------------------------------------------------
# 🔥 ONLY CHANGE: isolate brew failure so script does not stop bootstrap
# ---------------------------------------------------------------------------
set +e

log_info "Syncing Homebrew packages from Brewfile…"
"$BREW_BIN" bundle --file="$BREWFILE"
BUNDLE_EXIT=$?

"$BREW_BIN" bundle cleanup --force --file="$BREWFILE"
CLEANUP_EXIT=$?

set -e

if [[ $BUNDLE_EXIT -ne 0 ]]; then
    log_error "brew bundle failed (exit code $BUNDLE_EXIT) — continuing bootstrap"
else
    log_success "Packages synced"
fi

if [[ $CLEANUP_EXIT -ne 0 ]]; then
    log_error "brew cleanup failed (exit code $CLEANUP_EXIT) — continuing bootstrap"
else
    log_success "Packages synced"
fi
